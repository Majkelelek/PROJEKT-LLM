# =========================================================================
# Unified .gitignore for NeuroBench AI (React Frontend & .NET Backend)
# =========================================================================

# -------------------------------------------------------------------------
# Node.js / React (Frontend) Exclusions
# -------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Production / Build outputs
dist/
dist-ssr/
build/

# Local env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# -------------------------------------------------------------------------
# .NET / C# (Backend) Exclusions
# -------------------------------------------------------------------------
# Build folders
[Bb]in/
[Oo]bj/

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Mono auto generated files
mono_crash.*

# -------------------------------------------------------------------------
# IDEs and Text Editors
# -------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/settings.json

# JetBrains (Rider, WebStorm, etc.)
.idea/
*.sln.iml

# Visual Studio files
.vs/
*.userprefs
*.suo
*.suo.tmp

# -------------------------------------------------------------------------
# OS-specific files
# -------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
